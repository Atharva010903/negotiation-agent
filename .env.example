# ── Groq API ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Models (optional overrides) ──────────────────────────────
# BUYER_MODEL=qwen/qwen3-32b
# SELLER_MODEL=qwen/qwen3-32b
# MEDIATOR_MODEL=llama-3.1-8b-instant

# ── RAG Settings ──────────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_TOP_K=5

# ── Negotiation Defaults ─────────────────────────────────────────
# MAX_ROUNDS=10
# CONVERGENCE_THRESHOLD_PCT=2.0

# ── LLM Temperature ──────────────────────────────────────────────
# BUYER_TEMPERATURE=0.6
# SELLER_TEMPERATURE=0.5
# MEDIATOR_TEMPERATURE=0.1
